{
  "name": "Surge Write Queue",
  "doctype": "DocType",
  "module": "Surge Pos",
  "is_submittable": 0,
  "track_changes": 0,
  "autoname": "UUID",
  "fields": [
    {
      "fieldname": "client_req_id",
      "fieldtype": "Data",
      "label": "Client Request ID",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "terminal_id",
      "fieldtype": "Data",
      "label": "Terminal (User)",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "resource_type",
      "fieldtype": "Select",
      "label": "Resource Type",
      "options": "Invoice",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "payload",
      "fieldtype": "Long Text",
      "label": "Payload (JSON)",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nSyncing\nDone\nFailed\nConflict",
      "default": "Pending",
      "reqd": 1,
      "in_list_view": 1,
      "in_filter": 1
    },
    {
      "fieldname": "attempt_count",
      "fieldtype": "Int",
      "label": "Attempts",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "next_retry_at",
      "fieldtype": "Datetime",
      "label": "Next Retry At"
    },
    {
      "fieldname": "last_error",
      "fieldtype": "Long Text",
      "label": "Last Error"
    },
    {
      "fieldname": "synced_at",
      "fieldtype": "Datetime",
      "label": "Synced At"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1
    },
    {
      "role": "POS User",
      "read": 1, "write": 1, "create": 1
    }
  ]
}
